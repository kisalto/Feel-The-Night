{
  "compilerOptions": {
    "target": "ES2022",                  
    "module": "NodeNext",                
    "moduleResolution": "NodeNext",
    "rootDir": "./src",                  
    "outDir": "./dist",                 
    "strict": true,                     
    "esModuleInterop": true,            
    "skipLibCheck": true
  },
  "include": ["src/**/*", "api"],
  "exclude": ["node_modules", "dist"]
}